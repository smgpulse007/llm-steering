# Replace this value with your own token, or leave it blank and use `hf auth login`.
HF_TOKEN=replace-with-your-hf-token

# Default Hugging Face model used by the scripts in this repo.
HF_MODEL_ID=google/gemma-4-E2B-it
HF_MODEL_LOCAL_DIR=models/hf/google_gemma-4-E2B-it

# Local Ollama baseline.
OLLAMA_MODEL=gemma4
OLLAMA_BASE_URL=http://localhost:11434

# Experiment defaults.
DEFAULT_STEERING_LAYER=18
DEFAULT_STEERING_COEFFICIENT=1.5
MAX_NEW_TOKENS=96
